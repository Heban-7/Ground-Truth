{
  "schema_version": "0.1.0-draft",
  "benchmark_name": "tenacious_bench_v0.1",
  "description": "Draft schema for Tenacious sales outreach evaluation tasks.",
  "task_fields": {
    "id": "string",
    "source_mode": "trace_derived | programmatic | multi_llm_synthesis | hand_authored",
