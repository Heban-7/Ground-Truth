      "bench_summary_ref": "string",
      "pricing_ref": "string"
    },
    "candidate_output": {
      "subject": "string",
      "body": "string"
    },
    "ground_truth": {
      "required_elements": [
        "string"
      ],
      "forbidden_phrases": [
        "string"
      ],
      "max_body_words": "number",
      "single_ask_required": "boolean"
    },
    "rubric": {
      "direct": "1-5",
      "grounded": "1-5",
      "honest": "1-5",
      "professional": "1-5",
      "non_condescending": "1-5",
      "pass_threshold_per_dimension": 4
    }
  },
  "example_tasks": [
    {
      "id": "task_0001",
      "source_mode": "hand_authored",
      "partition": "dev",
      "difficulty": "easy",
      "input": {
        "prospect_name": "Maya",
        "company_name": "Acme AI",
        "channel": "email",
        "signal_brief": "$14M Series A in February and Python roles increased from 2 to 7 in 60 days.",
        "signal_confidence": "high",
        "ai_maturity_score": "2",
        "bench_summary_ref": "bench_summary.json",
        "pricing_ref": "pricing_sheet.md"
      },
      "candidate_output": {
        "subject": "Request: 15 minutes on your Q3 Python hiring",
        "body": "Hi Maya, You closed your $14M Series A in February and your open Python roles moved from 2 to 7 in the last 60 days. We place managed Python and data engineers with at least three hours of timezone overlap. Would 15 minutes next week be useful to compare options? Best, Yabi"
      },
      "ground_truth": {
        "required_elements": [
          "at_least_one_specific_signal",
          "one_clear_ask",
          "no_external_bench_term"
        ],
        "forbidden_phrases": [
          "world-class",
          "top talent",
          "quick chat",
          "just following up"
        ],
        "max_body_words": 120,
        "single_ask_required": true
      },
      "rubric": {
        "direct": 5,
        "grounded": 5,
        "honest": 5,
        "professional": 5,
        "non_condescending": 5,
        "pass_threshold_per_dimension": 4
      }
    }
  ]
